# LinkedIn Auto-Poster — Environment Variables
# Copy this file to .env and fill in your values.

# === REQUIRED ===

# LinkedIn OAuth credentials (from LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# LinkedIn access token (obtained via scripts/linkedin_setup.py)
LINKEDIN_ACCESS_TOKEN=your_access_token_here

# GitHub token (for GitHub Releases monitoring and Copilot SDK)
GITHUB_TOKEN=ghp_your_token_here

# === OPTIONAL ===

# LinkedIn refresh token (if your app tier supports it)
# LINKEDIN_REFRESH_TOKEN=your_refresh_token_here

# Override GitHub username for repo monitoring (default: from GITHUB_TOKEN)
# GITHUB_USER=your-github-username

# Override author name (default: from config.yaml)
# AUTHOR_NAME=Your Name
